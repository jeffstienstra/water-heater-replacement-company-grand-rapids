---
interface Props {
	title?: string;
	class?: string;
}

const { title = 'Water Heater Replacement Company on Google Maps', class: className = '' } = Astro.props;
---

<div class:list={['w-full overflow-hidden rounded-2xl', className]}>
	<iframe
		src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4593.3660773985!2d-85.84484248725073!3d42.90016670068645!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8819bbd7244ab427%3A0x6a6ad017d6cbd993!2sWater%20Heater%20Replacement%20Company!5e1!3m2!1sen!2sus!4v1777544737329!5m2!1sen!2sus"
		width="100%"
		height="450"
		style="border:0;"
		allowfullscreen
		loading="lazy"
		referrerpolicy="no-referrer-when-downgrade"
		title={title}
	></iframe>
</div>
