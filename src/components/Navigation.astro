---
import ThemeSelector from './ThemeSelector.astro';
import logoIcon from '../assets/images/whrc-logo-icon.png';
import logoText from '../assets/images/whrc-logo-text.png';
import fullLogo from '../assets/images/whrc-logo-horizontal-light-bg.svg';
import Phone from './icons/Phone.astro';
import CalendarClock from './icons/CalendarClock.astro';
import PriceReceipt from './icons/PriceReceipt.astro';

const { showNavigation = true } = Astro.props;
---

<div class="fixed top-0 left-0 w-full z-50 navbar bg-base-100 shadow-sm">
    <div class="sm:navbar-start w-100">
        <a class="px-0 w-fit navbar-start btn btn-ghost z-51"
            aria-label="Home | Water Heater Replacement Company of Grand Rapids"
            href="/">
            <img src={fullLogo.src}
                alt="Water Heater Replacement Company of Grand Rapids Logo"
                class="h-12 object-contain" />
        </a>
    </div>
    <div class="navbar-end">
        {showNavigation && (
                <div class="navbar-center hidden lg:flex justify-between">
                    <ul class="menu menu-horizontal px-1 mr-4">
                        <li>
                            <details class="details-menu">
                                <summary>Services</summary>
                                <ul class="p-2 w-64 top-6 right-0 z-50">
                                    <li><a aria-label="Water Heater Replacement" href="/services/water-heater-replacement/">Water Heater Replacement</a></li>
                                    <li><a aria-label="Water Heater Repair" href="/services/water-heater-repair/">Water Heater Repair</a></li>
                                    <li><a aria-label="Leaking Water Heater Emergency" href="/services/leaking-water-heater-emergency/">Leaking Water Heater Emergency</a></li>
                                </ul>
                            </details>
                        </li>
                        <li>
                            <details class="details-menu">
                                <summary>Resources</summary>
                                <ul class="p-2 w-64 top-6 right-0 z-50">
                                    <li><a aria-label="Why Choose Us" href="/why-us/">Why Choose Us</a></li>
                                    <li><a aria-label="Tank vs. Tankless — Compare" href="/resources/tank-vs-tankless-water-heaters/">Tank vs Tankless Comparison</a></li>
                                    <li><a aria-label="Tank Water Heaters" href="/resources/tank-water-heaters/">Tank Water Heaters</a></li>
                                    <li><a aria-label="Tankless Water Heaters" href="/resources/tankless-water-heaters/">Tankless Water Heaters</a></li>
                                    <li><a aria-label="How to Stop a Water Leak" href="/resources/how-to-stop-a-water-leak/">How to Stop a Water Leak</a></li>
                                    <li><a aria-label="Water Heater Installation Process" href="/resources/water-heater-installation-process-jenison-mi/">Water Heater Installation Process</a></li>
                                </ul>
                            </details>
                        </li>
                        <li>
                            <a aria-label="Service Area" href="/service-area/">Service Area</a>
                        </li>
                    </ul>
                </div>
                <a class="lg:mr-4 font-semibold w-7 h-7 flex items-center justify-center rounded-sm text-primary"
                    href='tel:6163150999'
                    aria-label='Click to call the Water Heater Replacement Company of Grand Rapids at 616-315-0999'>
                    <svg class="w-8 h-8 fill-current"
                        viewBox="3 3 18 18"
                        xmlns="http://www.w3.org/2000/svg">
                        <path d="m17.38 10.79-2.2-2.2c-.28-.28-.36-.67-.25-1.02.37-1.12.57-2.32.57-3.57 0-.55.45-1 1-1H20c.55 0 1 .45 1 1 0 9.39-7.61 17-17 17-.55 0-1-.45-1-1v-3.49c0-.55.45-1 1-1 1.24 0 2.45-.2 3.57-.57.35-.12.75-.03 1.02.24l2.2 2.2c2.83-1.45 5.15-3.76 6.59-6.59z"></path>
                    </svg>
                </a>
                    <div class="ml-4 hidden lg:block">
                        <a aria-label="Get My Exact Quote" href="/instant-quote/?step=1" class="btn btn-primary text-white w-full min-w-52 h-12">
                            <PriceReceipt />
                            Get My Exact Quote
                        </a>
                    </div>
        )}

        {showNavigation && (
            <div class="dropdown">
                <div aria-label="dropdown button" tabindex="0" role="button" class="btn btn-ghost lg:hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
                    </svg>
                </div>
                <ul
                    tabindex="0"
                    class="menu menu-sm right-1 dropdown-content bg-base-100 rounded-box z-1 mt-3 w-72 p-2 shadow gap-1"
                    >
                        <li>
                            <a aria-label="Services" href="/services/" class="text-lg font-bold">Services</a>
                            <ul class="p-2">
                                <li><a aria-label="Water Heater Replacement" href="/services/water-heater-replacement/" class="text-base font-semibold">Water Heater Replacement</a></li>
                                <li><a aria-label="Water Heater Repair" href="/services/water-heater-repair/" class="text-base font-semibold">Water Heater Repair</a></li>
                                <li><a aria-label="Leaking Water Heater Emergency" href="/services/leaking-water-heater-emergency/" class="text-base font-semibold">Leaking Water Heater Emergency</a></li>
                            </ul>
                        </li>
                    <li>
                    <p class="pointer-events-none text-lg font-bold" aria-label="parent">Resources</p>
                    <ul class="p-2">
                        <li>
                            <a aria-label="Why Choose Us" href="/why-us/" class="text-base font-semibold">Why Choose Us</a>
                        </li>
                        <li>
                            <a aria-label="Tank vs Tankless Comparison" href="/resources/tank-vs-tankless-water-heaters/" class="text-base font-semibold">Tank vs Tankless Comparison Guide</a>
                        </li>
                        <li>
                            <a aria-label="Tank Water Heaters" href="/resources/tank-water-heaters/" class="text-base font-semibold">Tank Water Heaters</a>
                        </li>
                        {/* <li>
                            <a aria-label="Power Vent Water Heaters" href="/resources/power-vent-water-heaters/">Power Vent Water Heaters</a>
                        </li> */}
                        <li>
                            <a aria-label="Tankless Water Heaters" href="/resources/tankless-water-heaters/" class="text-base font-semibold">Tankless Water Heaters</a>
                        </li>
                        <li>
                            <a aria-label="How to Stop a Water Leak" href="/resources/how-to-stop-a-water-leak/" class="text-base font-semibold">How to Stop a Water Leak</a>
                        </li>
                        <li>
                            <a aria-label="Water Heater Installation Process" href="/resources/water-heater-installation-process-jenison-mi/" class="text-base font-semibold">Water Heater Installation Process</a>
                        </li>
                    </ul>
                    <li>
                            <a aria-label="Service Area" href="/service-area/" class="text-lg font-bold">Service Area</a>
                    </li>
                    </li>
                        <div class="mt-2 lg:hidden w-full">
                            <a aria-label="exact quote" href="/instant-quote/?step=1" class="btn btn-primary text-white w-full h-12 px-0 my-8">
                                <PriceReceipt />
                                Get My Exact Quote
                            </a>
                            <a href="tel:616-315-0999" class="btn btn-outline text-primary text-lg font-semibold w-full h-12 px-0">
                                <Phone />
                                616-315-0999
                            </a>
                        </div>
                </ul>
            </div>
        )}
    </div>


<script>
    (function setupGlobalDetailsClose() {
        const closeOpenDetails = (event) => {
            const path = (event.composedPath && event.composedPath()) || (event.path) || (function(){
                const p = [];
                let el = event.target;
                while (el) { p.push(el); el = el.parentNode; }
                return p;
            })();

            document.querySelectorAll('details.details-menu[open]').forEach((el) => {
                if (!(el instanceof HTMLDetailsElement)) return;
                const clickedInside = path.includes(el) || el.contains(event.target);
                if (!clickedInside) el.open = false;
            });
        };

        document.addEventListener('pointerdown', closeOpenDetails, { passive: true });
        document.addEventListener('click', closeOpenDetails);

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                document.querySelectorAll('details.details-menu[open]').forEach((el) => { el.open = false; });
            }
        });
    })();
</script>
