---
const { class: className = '', ...props } = Astro.props;
---
<svg
    class={`${className}`}
    xmlns="http://www.w3.org/2000/svg"
    width={24}
    height={24}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width={2}
    stroke-linecap="round"
    stroke-linejoin="round"
    {...props}
>
    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
    <!-- Single photo frame -->
    <rect x="3" y="4" width="18" height="16" rx="2.5" />
    <!-- Sun -->
    <circle cx="7.2" cy="8.7" r="1.2" />
    <!-- Mountain outline -->
    <path d="M5.2 15.2l5.2 -4.9l4.2 4l2.7 -2.1l1.7 1.5" />
</svg>
