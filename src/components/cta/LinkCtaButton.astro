---
const {
    href = '#',
    label = 'Learn More',
    className = '',
    ariaLabel,
    variant = 'outline',
} = Astro.props;

const variantClass = variant === 'primary'
    ? 'btn-primary text-white'
    : 'btn-outline border-primary text-primary bg-transparent';
const baseClass = `btn ${variantClass} text-lg py-2 w-full max-w-xs mx-auto`;
const classes = className ? `${baseClass} ${className}`.trim() : baseClass;
const hasIcon = Astro.slots.has('icon');
---

<a href={href} aria-label={ariaLabel ?? label} class={classes}>
    {hasIcon && <slot name='icon' />}
    <span class='text-center'>{label}</span>
</a>
