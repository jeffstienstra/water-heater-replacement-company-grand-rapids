---
import { businessInfo } from '../data/businessInfo';
import { businessServices } from '../data/businessServices';
import { cities } from '../data/cities';
import { sortServicesByPageContext } from '../utils/sortServices';
import { sanitizeUrl } from '../utils/urls';

interface FaqItem {
	q: string;
	a: string;
}

interface Props {
	pageTitle: string;
	pageUrl: string;
	publishDate?: string;
	faqs?: FaqItem[];
}

const {
	pageTitle = 'Water Heater Replacement Company',
	pageUrl = 'https://waterheaterreplacementcompany.com',
	publishDate,
	faqs,
} = Astro.props;

const sortedServices = sortServicesByPageContext(businessServices, pageTitle, pageUrl);
const logoUrl = businessInfo.logo;
const websiteUrl = businessInfo.url;
const sameAsUrls = Object.values(businessInfo.social).filter(
	(link): link is string => typeof link === 'string' && link.trim().length > 0
);

const areaServedPlaces = [
	...cities.map(({ city, state, lat, lon, googleMapsUrl }) => ({
		'@type': 'City',
		name: city,
		...(googleMapsUrl ? { sameAs: googleMapsUrl } : {}),
		address: {
			'@type': 'PostalAddress',
			addressLocality: city,
			addressRegion: state,
			addressCountry: businessInfo.address.country,
		},
		geo: {
			'@type': 'GeoCoordinates',
			latitude: lat,
			longitude: lon,
		},
	})),
	{
		'@type': 'GeoCircle',
		geoMidpoint: {
			'@type': 'GeoCoordinates',
			latitude: businessInfo.geo.lat,
			longitude: businessInfo.geo.lng,
		},
		geoRadius: '48280',
	},
];
---

<script type="application/ld+json" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': `${websiteUrl}#organization`,
			name: businessInfo.name,
			url: websiteUrl,
			logo: {
				'@type': 'ImageObject',
				'@id': logoUrl,
				url: logoUrl,
				contentUrl: logoUrl,
				width: 600,
				height: 600,
			},
			image: { '@id': logoUrl },
			sameAs: sameAsUrls,
			foundingDate: businessInfo.foundingDate,
			hasCredential: {
                '@type': 'EducationalOccupationalCredential',
                name: 'Mechanical Contractor License',
                credentialCategory: 'license',
                identifier: '7117187',
                recognizedBy: {
                    '@type': 'Organization',
                    name: 'State of Michigan Bureau of Construction Codes',
                    url: 'https://www.michigan.gov/lara/bureau-list/bcc'
                }
            },
		},
		{
			'@type': 'WebSite',
			'@id': `${websiteUrl}#website`,
			url: websiteUrl,
			name: businessInfo.name,
			potentialAction: {
				'@type': 'SearchAction',
				target: {
					'@type': 'EntryPoint',
					urlTemplate: `${websiteUrl}/?s={search_term_string}`,
				},
				'query-input': 'required name=search_term_string',
			},
		},
		{
			'@type': 'WebPage',
			'@id': `${pageUrl}#webpage`,
			url: pageUrl,
			name: pageTitle,
			image: businessInfo.mainImage,
			primaryImageOfPage: { '@id': businessInfo.mainImage.url },
			isPartOf: { '@id': `${websiteUrl}#website` },
			mainEntity: { '@id': `${websiteUrl}#localbusiness` },
		},
		...(publishDate ? [
			{
				'@type': 'Article',
				'@id': `${pageUrl}#article`,
				headline: pageTitle,
				datePublished: publishDate,
				author: {
					'@type': 'Organization',
					'@id': `${websiteUrl}#organization`,
				},
				publisher: {
					'@type': 'Organization',
					'@id': `${websiteUrl}#organization`,
				},
				mainEntityOfPage: {
					'@type': 'WebPage',
					'@id': pageUrl,
				},
			},
		] : []),
		{
			'@type': ['Plumber', 'HVACBusiness', 'HomeAndConstructionBusiness', 'LocalBusiness'],
			'@id': `${websiteUrl}#localbusiness`,
			name: businessInfo.name,
			description: businessInfo.description,
			image: businessInfo.mainImage,
			url: websiteUrl,
			telephone: businessInfo.primaryPhone,
			email: businessInfo.email,
			address: {
				'@type': 'PostalAddress',
				streetAddress: businessInfo.address.street,
				addressLocality: businessInfo.address.city,
				addressRegion: businessInfo.address.state,
				postalCode: businessInfo.address.zip,
				addressCountry: businessInfo.address.country,
			},
			geo: {
				'@type': 'GeoCoordinates',
				latitude: businessInfo.geo.lat,
				longitude: businessInfo.geo.lng,
			},
			openingHoursSpecification: businessInfo.hours,
			aggregateRating: {
				'@type': 'AggregateRating',
				ratingValue: '5.0',
				reviewCount: '6',
				bestRating: '5',
				worstRating: '1',
			},
			priceRange: '$$',
			knowsAbout: [
				'Water Heater Replacement',
				'Water Heater Repair',
				'Tankless Water Heaters',
				'Tank Water Heaters',
				'Gas Water Heaters',
				'Electric Water Heaters',
				'Power Vent Water Heaters',
				'Natural Draft Water Heaters',
				'Heat Pump Water Heaters',
				'Energy Efficient Water Heaters',
				'Rheem Water Heaters',
				'A.O. Smith Water Heaters',
				'Bradford White Water Heaters',
			],
			areaServed: areaServedPlaces,
			potentialAction: {
				'@type': 'TradeAction',
				name: 'Get a Free Instant Quote',
				description: 'Get an exact installed water heater price in 30 seconds with no personal info required.',
				target: {
					'@type': 'EntryPoint',
					urlTemplate: 'https://waterheaterreplacementcompany.com/instant-quote/?step=1',
					actionPlatform: [
						'http://schema.org/DesktopWebPlatform',
						'http://schema.org/MobileWebPlatform'
					]
				}
			},
			hasOfferCatalog: { '@id': `${websiteUrl}#services` },
			hasMap: 'https://www.google.com/maps/place/Water+Heater+Replacement+Company/@42.9035951,-85.9174956,13.15z/data=!4m7!3m6!1s0x8819bbd7244ab427:0x6a6ad017d6cbd993!8m2!3d42.9001628!4d-85.8422622!15sCiBXYXRlciBIZWF0ZXIgUmVwbGFjZW1lbnQgQ29tcGFueVoiIiB3YXRlciBoZWF0ZXIgcmVwbGFjZW1lbnQgY29tcGFueZIBB3BsdW1iZXKaAURDaTlEUVVsUlFVTnZaRU5vZEhsalJqbHZUMnBqTWxvelRrWlJWR3MwVWtoRk5GcEdTbkJoTUdoT1pGZDNOVTVGUlJBQuABAPoBBQiwARA-!16s%2Fg%2F11yycvvfzy',
			sameAs: sameAsUrls,
		},
		{
			'@type': 'OfferCatalog',
			'@id': `${websiteUrl}#services`,
			name: 'Water Heater Services',
			itemListElement: sortedServices.map(service => ({
				'@type': 'Offer',
				itemOffered: {
					'@type': 'Service',
					name: service.name,
					description: service.description,
					url: sanitizeUrl(`${websiteUrl}/${service.url}`),
					areaServed: 'Grand Rapids Metropolitan Area and West Michigan',
					provider: { '@id': `${websiteUrl}#localbusiness` },
					serviceType: service.serviceType,
					brand: [
						{
							'@type': 'Brand',
							name: 'Rheem',
						},
						{
							'@type': 'Brand',
							name: 'AO Smith',
						},
						{
							'@type': 'Brand',
							name: 'Bradford White',
						}
					],
					offers: {
						'@type': 'Offer',
						url: `${websiteUrl}/instant-quote/?step=1`,
						priceSpecification: {
							'@type': 'PriceSpecification',
							price: 0,
							priceCurrency: 'USD',
							description: 'Free Estimates - Instant Quotes Available Online',
						},
					},
				},
			})),
		},
	],
})} />

{faqs && faqs.length > 0 && (
	<script type="application/ld+json" set:html={JSON.stringify({
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(({ q, a }) => ({
			'@type': 'Question',
			name: q,
			acceptedAnswer: {
				'@type': 'Answer',
				text: a,
			},
		})),
	})} />
)}

