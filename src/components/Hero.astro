---
import PriceReceipt from './icons/PriceReceipt.astro';
import Phone from './icons/Phone.astro';
import heroImg from '../assets/images/whrc-van-image.webp';
---

<section class="bg-base-100 text-base-content">
    <div class="max-w-6xl mx-auto px-6 py-6 lg:py-20 grid lg:grid-cols-2 gap-10 items-center">

        <!-- Left: copy -->
        <div class="flex flex-col gap-5">

            <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full w-fit">
                No Sales Commissions. No Upselling. Grand Rapids & West Michigan.
            </span>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight">
                Water Heater Replacement in Grand Rapids. Exact Price Upfront.
            </h1>

            <p class="text-lg sm:text-xl text-gray-600 max-w-lg">
                Skip the salesman. Get your exact installed price in 30 seconds, schedule same-day or next-day service in minutes, and get back to your day.
            </p>

            <!-- social proof quote -->
            <div class="bg-primary/5 border border-primary/20 rounded-2xl px-4 py-3 flex flex-wrap items-baseline gap-x-2 max-w-fit">
                <span class="text-sm font-semibold text-primary">"Professional, friendly, fast, and very knowledgeable. Would highly recommend!"</span>
                <span class="text-sm text-gray-500 whitespace-nowrap">~Pat from Jenison</span>
            </div>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-3">
                <a href="/instant-quote/?step=1" class="btn btn-primary btn-lg text-white shadow-md">
                    <PriceReceipt />
                    Get My Exact Quote Now
                </a>
                <a href="tel:616-315-0999" class="btn btn-outline btn-lg border-primary text-primary">
                    <Phone />
                    Call 616-315-0999
                </a>
            </div>
			<p class="text-sm text-gray-500">Our techs do not receive sales commissions and don't benefit from upsells.</p>
        </div>

        <!-- Right: image -->
        <div class="relative">
            <img
                src={heroImg.src}
                alt="Water Heater Replacement Company service van preparing for a water heater installation in Grand Rapids"
                loading="eager"
                class="w-full rounded-3xl object-cover shadow-xl"
            />
            <!-- floating stat card -->
            <div class="absolute -bottom-5 -left-4 sm:left-4 bg-white border border-base-300 rounded-2xl shadow-lg px-5 py-4 flex items-center gap-3">
                <span class="text-3xl font-black text-primary">2-Year</span>
                <span class="text-sm font-semibold text-gray-700 leading-snug">Labor<br/>Warranties</span>
            </div>
        </div>

    </div>
</section>