---
import QuoteCtaButton from './cta/QuoteCtaButton.astro';
import PhoneCtaButton from './cta/PhoneCtaButton.astro';
import heroImg from '../assets/images/whrc-van-image-house.webp';
---

<section class="bg-base-100 text-base-content">
    <div class="max-w-6xl mx-auto px-6 py-6 lg:py-20 grid lg:grid-cols-2 gap-10 items-center">

        <!-- Left: copy -->
        <div class="flex flex-col gap-5">

            <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full w-fit">
                No Sales Commissions. No Upselling. Grand Rapids & West Michigan.
            </span>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight">
                Water Heater Replacement in Grand Rapids. Exact Price Upfront.
            </h1>

            <p class="text-lg sm:text-xl text-gray-600 max-w-lg">
                Skip the salesman. Get your exact installed price in 30 seconds, schedule same-day or next-day service in minutes, and get back to your day.
            </p>

            <!-- social proof quote -->
            <div class="bg-primary/5 border border-primary/20 rounded-lg px-4 py-3 flex flex-wrap items-baseline gap-x-2 max-w-fit">
                <span class="text-sm font-semibold text-primary">"Professional, friendly, fast, and very knowledgeable. Would highly recommend!"</span>
                <span class="text-sm text-gray-500 whitespace-nowrap">~Pat from Jenison</span>
            </div>

            <!-- CTAs -->
            <div class="flex flex-col gap-3">
                <QuoteCtaButton label="Get My Exact Quote Now" />
                <PhoneCtaButton label="Call 616-315-0999" />
            </div>
			<!-- <p class="text-sm text-gray-500">Our techs do not receive sales commissions.</p> -->
        </div>

        <!-- Right: image -->
        <div class="flex flex-col overflow-hidden rounded-lg shadow-xl bg-base-100 border border-base-300 lg:h-[520px]">
            <div class="flex-1 min-h-0">
                <img
                    src={heroImg.src}
                    alt="Water Heater Replacement Company service van preparing for a water heater installation in Grand Rapids"
                    loading="eager"
                    class="h-full w-full object-cover"
                />
            </div>
            <div class="bg-primary text-primary-content px-5 py-4 border-t border-base-300/20">
                <div class="flex items-center gap-4">
                    <span class="text-3xl sm:text-4xl font-black leading-none">2-Year</span>
                    <span class="text-sm font-semibold leading-snug opacity-95">Labor Warranties<br/>With Every Install</span>
                </div>
            </div>
        </div>

    </div>
</section>