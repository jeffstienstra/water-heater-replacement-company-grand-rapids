---
interface Props {
    faqs?: { q: string; a: string }[];
    name?: string;
    title?: string;
}

const {
    faqs = [],
    name = "faq-home",
    title = "Common Questions",
} = Astro.props;
---

<section id="faq" class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
    <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
            <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">FAQ</span>
            <h2 class="text-3xl sm:text-4xl font-bold">{title}</h2>
        </div>
        <div class="flex flex-col gap-3">
            {faqs?.map(({ q, a }, i) => (
                <div class="collapse collapse-arrow border border-base-300 rounded-2xl bg-base-100">
                    <input type="radio" name={name} checked={i === 0} />
                    <div class="collapse-title text-base font-semibold py-5 pr-10">{q}</div>
                    <div class="collapse-content text-gray-600 text-sm leading-relaxed">
                        <p set:html={a} />
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
