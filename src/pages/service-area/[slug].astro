---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import Faq from "../../components/Faq.astro";
import PriceReceipt from "../../components/icons/PriceReceipt.astro";
import Phone from "../../components/icons/Phone.astro";
import { cities } from "../../data/cities";
import type { CityEntry } from "../../data/cities";

const STATIC_CITY_PAGES = ['jenison', 'grandville', 'hudsonville'];

export async function getStaticPaths() {
    const staticCityPages = ['jenison', 'grandville', 'hudsonville'];
    return cities
        .filter((city) => !staticCityPages.includes(city.slug))
        .map((city) => ({
            params: { slug: city.slug },
            props: { city },
        }));
}

interface Props {
    city: CityEntry;
}

const { city } = Astro.props;
const canonicalUrl = `https://waterheaterreplacementcompany.com/service-area/${city.slug}/`;
---

<BaseLayout
    title={`Water Heater Replacement in ${city.city}, MI | Same-Day Service`}
    description={city.description}
    canonical={canonicalUrl}
    faqs={city.faqs}
>

    <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
    <section class="bg-base-100 text-base-content">
        <div class="max-w-6xl mx-auto px-6 py-12 sm:py-20">
            <div class="max-w-3xl flex flex-col gap-6">
                <div class="flex flex-wrap">
                    <h1 class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">
                        Water Heater Service · {city.city}, {city.state}
                    </h1>
                    <span class="text-4xl sm:text-5xl font-black leading-tight tracking-tight mb-4 block w-full">
                        Water Heater Replacement &amp; Repair in {city.city}, MI
                    </span>
                    <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mt-4">
                        {city.intro}
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="/instant-quote/?step=1" class="btn btn-primary btn-lg text-white shadow-md">
                        <PriceReceipt />
                        Get My Exact Quote
                    </a>
                    <a href="tel:616-315-0999" class="btn btn-outline btn-lg border-primary text-primary">
                        <Phone />
                        616-315-0999
                    </a>
                </div>
            </div>
        </div>
    </section>

    <TrustStrip />

    <!-- ─── SERVICES ─────────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-200 text-base-content border-t border-base-300">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-14">
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">What We Do</span>
                <h2 class="text-3xl sm:text-4xl font-bold mb-3">Water Heater Services in {city.city}</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    We handle every water heater situation — from routine replacements to weekend emergencies. Same upfront pricing, no matter what you need.
                </p>
            </div>
            <div class="grid gap-6 sm:grid-cols-3">
                {[
                    {
                        name: 'Water Heater Replacement',
                        url: '/services/water-heater-replacement/',
                        desc: 'Full tank or tankless replacement with same-day availability. Upfront price before we arrive — no surprises at the door.',
                        icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
                    },
                    {
                        name: 'Water Heater Repair',
                        url: '/services/water-heater-repair/',
                        desc: 'Honest repair diagnosis from commission-free technicians. If it can be fixed for less, we will tell you.',
                        icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
                    },
                    {
                        name: 'Leaking Water Heater',
                        url: '/services/leaking-water-heater-emergency/',
                        desc: 'Tank leak? Call us immediately. We respond fast to prevent water damage and get your hot water restored the same day.',
                        icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
                    },
                ].map(({ name, url, desc, icon }) => (
                    <a href={url} class="flex flex-col gap-4 p-7 bg-base-100 rounded-2xl border border-base-300 shadow-sm hover:shadow-md transition-shadow group">
                        <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg text-base-content mb-2 group-hover:text-primary transition-colors">{name}</h3>
                            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
                        </div>
                        <span class="text-sm font-semibold text-primary mt-auto">Learn more →</span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <!-- ─── WHY US CALLOUT ────────────────────────────────────────────────────── -->
    <section class="py-14 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center gap-8 bg-primary/5 border border-primary/20 rounded-3xl p-8 sm:p-10">
            <div class="shrink-0 w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
            </div>
            <div>
                <h2 class="text-xl font-bold mb-2">Why {city.city} Homeowners Choose Us</h2>
                <p class="text-gray-600 leading-relaxed mb-4">We don't pay our technicians commissions — which means no upsells, no unnecessary red-tagging, no pressure. Just an honest diagnosis and a fair, published price before we ever arrive.</p>
                <a href="/why-us/" class="text-sm font-semibold text-primary hover:underline">Learn about our zero-commission model →</a>
            </div>
        </div>
    </section>

    <!-- ─── FAQ ───────────────────────────────────────────────────────────────── -->
    <Faq
        faqs={city.faqs}
        name={`faq-${city.slug}`}
        title={`Water Heater Questions in ${city.city}`}
    />

    <!-- ─── CTA ───────────────────────────────────────────────────────────────── -->
    <Cta
        title={`Ready for Hot Water in ${city.city}?`}
        subtitle="Get your exact installed price in 30 seconds. No hidden fees, no pressure, no personal info required."
    />

</BaseLayout>
