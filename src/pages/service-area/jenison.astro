---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import Faq from "../../components/Faq.astro";
import PriceReceipt from "../../components/icons/PriceReceipt.astro";
import Phone from "../../components/icons/Phone.astro";

const faqs = [
	{
		q: "How fast can you respond to a water heater emergency in Jenison?",
		a: "Because our office and dispatch are based right here in Jenison, we're often the fastest to respond in the area. For urgent leaks or a completely failed unit, call us directly at <a href='tel:616-315-0999' class='text-primary underline'>616-315-0999</a> - same-day & next-day service is our standard, not a premium."
	},
	{
		q: "Do you pull permits for water heater replacements in Jenison, MI?",
		a: "Yes - every time, no exceptions. Local permits are required by the State of Michigan for water heater replacements. We handle the permit application, scheduling, and inspection coordination as part of every job. If a contractor tells you a permit isn't needed in Jenison, walk away - it's required by law, and skipping it voids your manufacturer warranty and creates liability for you as the homeowner."
	},
	{
		q: "My Jenison home has hard well water. Will that affect my new water heater?",
		a: "Hard water is one of the most common causes of premature water heater failure in the Jenison area. The mineral deposits it leaves behind - calcium and magnesium scale - clog tank interiors, coat heating elements, and degrade anode rods faster than city water would. We factor your water source into our recommendations and can advise on sediment-flushing maintenance to extend the life of your new unit."
	},
	{
		q: "What type of water heater works best in Jenison homes?",
		a: "It depends on your home's age, fuel type, and household size. Most Jenison homes - especially the ranch-style builds from the 1970s and 80s - are set up for natural draft gas tanks and a like-for-like replacement is the simplest and most cost-effective option. Newer homes or those with a good gas supply and venting flexibility are strong candidates for tankless upgrades. We'll tell you which makes sense for your specific home - no upsell."
	},
	{
		q: "How long does water heater replacement take in Jenison?",
		a: "Most straightforward tank replacements in Jenison take 2–3 hours from arrival to hot water running. Tankless installations or situations requiring gas line or venting work can take 4–6 hours. We give you a realistic timeline when you book so you're not left waiting."
	},
	{
		q: "Is Water Heater Replacement Company actually local to Jenison?",
		a: "Yes - we're based in Jenison. Our office, trucks, and team are all here in the community. That's why we're often the fastest to arrive and why we have the highest concentration of completed jobs in the area. We know Jenison neighborhoods, permit offices, and inspection schedules better than any out-of-area company."
	},
];
