---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import Faq from "../../components/Faq.astro";
import PriceReceipt from "../../components/icons/PriceReceipt.astro";
import Phone from "../../components/icons/Phone.astro";

const faqs = [
	{
		q: "Do you replace water heaters in Hudsonville, MI?",
		a: "Yes — Hudsonville is a regular part of our service area. We typically have same-day or next-day availability throughout Hudsonville and the surrounding Ottawa County area. Call <a href='tel:616-315-0999' class='text-primary underline'>616-315-0999</a> or use the instant quote tool to get started."
	},
	{
		q: "Our Hudsonville home has well water. Does that affect which water heater we should get?",
		a: "It does — and it's one of the most important factors we ask about. Hard well water contains high mineral concentrations that accelerate scale buildup inside tank units, clog heating elements, and corrode anode rods faster than municipal water would. In homes with well water, we often recommend a slightly larger or higher-efficiency unit to compensate, and we advise on a regular annual flushing schedule to extend the life of your new water heater. For tankless units, proper inlet filtration is essential on a well."
	},
	{
		q: "Do you pull permits for water heater replacements in Hudsonville?",
		a: "Yes — every time. The State of Michigan requires a mechanical permit from the local jurisdiction for every water heater installation. We handle the application, inspection scheduling, and coordination as part of every job. It's included in your quoted price. Skipping the permit isn't legal, and it voids your manufacturer warranty. Any contractor suggesting otherwise should raise a red flag."
	},
	{
		q: "We just bought a newer Hudsonville home. How do I know if the water heater needs to be replaced?",
		a: "Check the label on the tank — the serial number encodes the manufacturing date on most brands. If it's over 10 years old, budgeting for replacement in the next 1–2 years is smart. Signs of an impending failure include: rust-colored hot water, popping or rumbling sounds (sediment), moisture around the base, or inconsistent temperatures. Our instant quote tool will show you what a replacement would cost so you can plan ahead."
	},
	{
		q: "Can you upgrade a Hudsonville home from tank to tankless?",
		a: "In many newer Hudsonville homes, yes — the gas supply and venting infrastructure is often better suited to tankless conversion than older builds. We verify your gas line size and existing venting configuration before confirming compatibility. If well water is a factor, we'll also discuss inlet filter requirements. If your home is ready, we include all conversion costs in your upfront quote — no hidden charges for gas line or venting work discovered after arrival."
	},
	{
		q: "How long does water heater replacement take in a Hudsonville home?",
		a: "Most standard tank replacements take 2–3 hours. Tankless conversions or jobs requiring gas line or venting upgrades typically run 4–5 hours. We give you a realistic timeline when you book so you can plan your day. Same-day and next-day appointments are regularly available in Hudsonville."
	},
];
