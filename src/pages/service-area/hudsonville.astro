	<!-- ─── LOCAL INTRO ───────────────────────────────────────────────────────── -->
	<section class="py-20 px-6 bg-base-200 text-base-content border-t border-base-300">
		<div class="max-w-4xl mx-auto">
			<span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">Serving Hudsonville</span>
			<h2 class="text-3xl sm:text-4xl font-bold mb-6">Serving Hudsonville's Growing Families — From New Builds to Established Neighborhoods</h2>
			<div class="space-y-4 text-gray-700 text-base leading-relaxed">
