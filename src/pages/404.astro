---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteCtaButton from '../components/cta/QuoteCtaButton.astro';
import PhoneCtaButton from '../components/cta/PhoneCtaButton.astro';

const metadata = {
  title: `Oops! - This isn't ready yet...`,
  description: `Sorry, this page is still in the oven. But dont worry, our phones work! :)`,
  robots: {
    index: false,
    follow: false,
  },
}
---

<BaseLayout metadata={metadata}>
  <section class="flex items-center h-full p-2 pt-8">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <span class="mb-8 text-center text-primary">Oops! We're still working on this page, but our phone is on!</span>
      <p class="text-2xl text-center text-primary">Call <a aria-label="call 616-315-0999" href="tel:616-315-0999" class="underline">616-315-0999</a></p>
      <p class="text-2xl text-center text-primary mb-8">Getting a new water heater is a breeze with the Water Heater Replacement Company.</p>
      <span class="sr-only">Error</span>
      <QuoteCtaButton label="Get An Instant Quote" className="mb-4" />
      <PhoneCtaButton className="mb-4" />
</div>
  </section>
</BaseLayout>
