---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import SocialProof from "../../components/SocialProof.astro";
import PriceReceipt from "../../components/icons/PriceReceipt.astro";
import Phone from "../../components/icons/Phone.astro";
import heroImg from "../../assets/images/whrc-van-image.webp";
import pvImg from "../../assets/images/wh-pv.webp";
import techImg from "../../assets/images/wh-tech1.jpg";
import UnitTypes from "../../components/UnitTypes.astro";
import TrustStrip from "../../components/TrustStrip.astro";
import Faq from "../../components/Faq.astro";

const faqs = [
    {
        q: "Do you charge a diagnostic fee?",
        a: "Yes, we charge a $75 diagnostic fee. This covers our time and expertise to thoroughly inspect your unit, identify the root cause of the problem, and provide you with a clear written estimate for the repair. If you choose to proceed with the repair, the diagnostic fee is applied toward the total cost. Companies that advertise 'free diagnostics' often push unnecessary repairs or replacements to recoup their costs. We prefer to be upfront about our fees and provide straighforward, transparent pricing that is not influenced by sales commissions.",
    },
    {
        q: "What if you come out and determine it can't be repaired?",
        a: "If replacement is the right move, we'll be straightforward with you and can provide a quote on the spot for a same-day or next-day replacement so you're not waiting on a second appointment. Your service fee will be applied toward the cost of the replacement if you choose to go that route. Otherwise, the service fee is expected to be paid and you are free to decline further service. We want to make sure you have all the information you need to make the best decision for your home and budget, without any pressure or upselling tactics.",
    },
    {
        q: "Do you repair both gas and electric water heaters?",
        a: "Yes. We service both gas and electric tank water heaters and tankless on-demand water heaters throughout the Grand Rapids and West Michigan area, including natural draft, power vent, and direct vent gas configurations.",
    },
    {
        q: "Do you repair tankless water heaters?",
        a: "Yes. Tankless repairs are more complex and parts-dependent than tank water heaters. Our technicians are trained to troubleshoot and repair all manner of issues with tankless units, but the cost and feasibility of repairs can vary widely based on the specific problem and the unit's age. We approach tankless repairs with the same honest, transparent philosophy as our tank water heater services — if a repair makes sense, we'll recommend it. If replacement is the better long-term solution, we'll provide a clear quote and let you decide without any pressure.",
    },
    {
        q: "Is a repaired water heater covered under warranty?",
        a: "Yes — our labor on repairs is covered by our labor warranty. Replacement parts may carry a manufacturer's warranty depending on the component. We document everything installed so you have a clear warranty record.",
    },
    {
        q: "How do I know if it's worth repairing vs. replacing?",
        a: `A good rule of thumb: if the repair costs more than 50% of a new unit and the tank is over 8 years old, replacement is usually the smarter investment. For tankless systems, if the repair costs more than 50% of a new unit and the system is over 10-15 years old, replacement is often the better choice. We'll walk you through both numbers side-by-side so the decision is easy. You can also get a <a href="/instant-quote/?step=1" class="text-primary underline font-semibold">replacement quote in 30 seconds</a> before we even arrive.`,
    },
];
---

<BaseLayout
    title="Water Heater Repair in Grand Rapids | Honest Diagnosis, No Upsells"
    description="Water heater not working in Grand Rapids? We diagnose the problem honestly and tell you whether repair or replacement makes more sense. Call 616-315-0999."
    canonical="https://waterheaterreplacementcompany.com/services/water-heater-repair/"
    faqs={faqs}
>

    <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
    <section class="bg-base-100 text-base-content">
        <div class="max-w-6xl mx-auto px-6 py-12 sm:py-20 grid md:grid-cols-2 gap-10 items-center">

            <!-- Left: copy -->
            <div class="flex flex-col gap-6">
                <div>
                    <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">
                        Fast, Honest Service
                    </span>
                    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight mb-4">
                        Water Heater Repair in Grand Rapids & West Michigan
                    </h1>
                    <p class="text-lg sm:text-xl text-gray-600 max-w-lg">
                        Our technicians never receive sales commissions so we can provide an honest diagnosis. We'll provide a clear recommendation—whether that’s a simple repair or a full replacement.
                    </p>
                </div>
                <div class="bg-primary/5 border border-primary/50 rounded-2xl shadow-md p-2 flex flex-wrap items-center max-w-fit px-4">
                    <span class="text-sm font-semibold text-primary">"Communicative, honest, affordable, and does outstanding work...10/10!" </span>
                    <span class="text-sm text-gray-700 leading-snug">~Nicholas, Grand Rapids</span>
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="tel:616-315-0999" class="btn btn-primary btn-lg text-white shadow-md max-w-fit">
                        <Phone />
                        Call Now For Service
                    </a>
                    <!-- <a href="/instant-quote/?step=1" class="btn btn-outline btn-lg border-primary text-primary">
                        <PriceReceipt class="text-primary" />
                        Get My Exact Quote
                    </a> -->
                </div>


                <p class="text-sm text-gray-500">Our techs do not receive sales commissions and don't benefit from upsells.</p>

                <!-- Trust badges -->
                <!-- <div class="hidden grid-cols-2 gap-3 pt-2">
                    {[
                        "Licensed & Insured",
                        "Service All Tank & Tankless Models",
                        "Clear Pricing Before We Start",
                        "Honest Diagnosis, No Upsells",
                        "Serving Grand Rapids & West Michigan",
                        "Fast, Reliable Service",
                    ].map((badge) => (
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700">
                            <span class="brand-check shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            {badge}
                        </div>
                    ))}
                </div> -->
            </div>

            <!-- Right: image -->
            <div class="relative">
                <img
                    src={heroImg.src}
                    alt="Water Heater Replacement Company technician diagnosing a water heater problem in Grand Rapids"
                    loading="eager"
                    class="w-full rounded-3xl object-fit shadow-xl"
                />
                <!-- floating trust card -->
                <div class="absolute -bottom-5 -left-4 sm:left-4 bg-white border border-base-300 rounded-2xl shadow-lg p-2 md:p-4 flex items-center gap-3">
                    <span class="text-2xl md:text-3xl font-black text-primary">ZERO</span>
                    <span class="text-sm font-semibold text-gray-700 leading-snug">Sales Commissions</span>
                </div>

            </div>
        </div>
    </section>

    <TrustStrip />

    <!-- ─── PROBLEMS WE REPAIR — 6 CARDS ─────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-14">
                <span class="inline-block bg-secondary/10 text-secondary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">What We Fix</span>
                <h2 class="text-3xl sm:text-4xl font-bold mb-3">Common Water Heater Problems We Repair</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Many issues come down to a single failed component. We identify the root cause and give you a clear price before any work starts.
                </p>
            </div>

            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {[
                    {
                        title: "No Hot Water",
                        desc: "A complete loss of hot water is often caused by things like a faulty thermostat or gas valve, a pilot light that won't stay lit, or a tripped breaker. These issues can often be repaired without a full replacement.",
                        icon: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z",
                    },
                    {
                        title: "Not Enough Hot Water",
                        desc: "Running out of hot water faster than usual often points to a worn-out lower heating element, heavy sediment buildup reducing capacity, or a unit that's simply undersized for your household.",
                        icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
                    },
                    {
                        title: "Popping or Rumbling Noises",
                        desc: "Loud banging, popping, or rumbling from your tank is usually caused by hardened sediment on the tank floor. It reduces efficiency, reduces capacity and accelerates corrosion of the tank if left untreated.",
                        icon: "M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 001.414 1.414m2.828-9.9a9 9 0 0112.728 0",
                    },
                    {
                        title: "Pressure Relief Valve Dripping",
                        desc: "A T&P valve that weeps or drips may indicate excessive system pressure, overheating, or a valve that has simply worn out and needs to be replaced — a safety-critical repair.",
                        icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
                    },
                    {
                        title: "Rusty or Discolored Water",
                        desc: "Brown or reddish hot water is a sign of a worn out anode rod or early internal tank corrosion. Catching it early may allow a rod replacement. Advanced corrosion typically means replacement.",
                        icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4",
                    },
                    {
                        title: "Pilot Light Won't Stay Lit",
                        desc: "On gas units, a pilot that keeps going out usually points to a worn thermocouple, a dirty pilot orifice, a faulty gas valve, or a venting issue that starves the flame of combustion air.",
                        icon: "M13 10V3L4 14h7v7l9-11h-7z",
                    },
                ].map(({ title, desc, icon }) => (
                    <div class="flex gap-4 p-6 bg-base-100 rounded-2xl border border-base-300 shadow-sm hover:shadow-md transition-shadow">
                        <div class="shrink-0 w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mt-0.5">
                            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-base-content mb-1">{title}</h3>
                            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ─── HOW IT WORKS ──────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-200 text-base-content border-t border-base-300">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-14">
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Our Process</span>
                <h2 class="text-3xl sm:text-4xl font-bold">Simple, Transparent, No Commissions</h2>
            </div>

            <div class="relative grid sm:grid-cols-3 gap-8">
                <div class="hidden sm:block absolute top-8 left-[calc(16.66%+1rem)] right-[calc(16.66%+1rem)] h-px bg-primary/20"></div>

                {[
                    {
                        n: "01",
                        title: "Diagnose the Problem",
                        desc: "We inspect your unit, identify the root cause, and explain exactly what's wrong in plain language. No technical jargon, no guesswork.",
                        href: "tel:616-315-0999",
                        cta: "Call to Schedule →",
                    },
                    {
                        n: "02",
                        title: "Get a Clear Price",
                        desc: "Before any work begins, you get a clear repair estimate. If it is a major repair, we'll also share a replacement quote so you can make an informed, pressure-free decision.",
                        href: null,
                        cta: null,
                    },
                    {
                        n: "03",
                        title: "We Fix It Right",
                        desc: "Once you approve, we complete the repair, test the unit thoroughly, and clean up before we leave. Our work is backed by our labor warranty.",
                        href: null,
                        cta: null,
                    },
                ].map(({ n, title, desc, href, cta }) => (
                    <div class="flex flex-col items-center text-center gap-3">
                        <div class="w-16 h-16 rounded-full bg-primary text-white text-xl font-black flex items-center justify-center shadow-md z-10">
                            {n}
                        </div>
                        <h3 class="text-xl font-bold">{title}</h3>
                        <p class="text-gray-600 text-sm leading-relaxed">{desc}</p>
                        {href && cta && (
                            <a href={href} class="text-primary font-semibold text-sm underline-offset-2 hover:underline">{cta}</a>
                        )}
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ─── REPAIR VS. REPLACE ────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Our Honest Take</span>
                <h2 class="text-3xl sm:text-4xl font-bold mb-3">Repair vs. Replace: The Age-Old Question</h2>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto">
                    We're not going to push you into a new unit if a repair makes sense. And our technicians won't benefit from recommending a replacement. But we also don't want you to throw money at a dying water heater that may fail again soon. Here's how we think about it.
                </p>
            </div>

            <div class="grid gap-6 sm:grid-cols-3">
                <div class="bg-base-100 rounded-2xl p-7 border-2 border-primary/30 shadow-sm flex flex-col gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center">
                        <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-primary">Repair Makes Sense When...</h3>
                    <ul class="space-y-2 text-sm text-gray-600">
                        <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">·</span> The unit is under 8 years old</li>
                        <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">·</span> The failure is isolated to one component</li>
                        <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">·</span> Repair cost is well under half the replacement cost</li>
                        <li class="flex items-start gap-2"><span class="text-primary font-bold mt-0.5">·</span> The tank shows no signs of corrosion</li>
                    </ul>
                </div>

                <div class="bg-base-100 rounded-2xl p-7 border-2 border-secondary/30 shadow-sm flex flex-col gap-4">
                    <div class="w-11 h-11 rounded-xl bg-secondary/10 flex items-center justify-center">
                        <svg class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-secondary">Could Go Either Way When...</h3>
                    <ul class="space-y-2 text-sm text-gray-600">
                        <li class="flex items-start gap-2"><span class="text-secondary font-bold mt-0.5">·</span> The unit is 8–10 years old</li>
                        <li class="flex items-start gap-2"><span class="text-secondary font-bold mt-0.5">·</span> This is the second or third repair in recent years</li>
                        <li class="flex items-start gap-2"><span class="text-secondary font-bold mt-0.5">·</span> Efficiency has noticeably declined</li>
                        <li class="flex items-start gap-2"><span class="text-secondary font-bold mt-0.5">·</span> Early signs of rust or scale are visible</li>
                    </ul>
                </div>

                <div class="bg-base-100 rounded-2xl p-7 border-2 border-red-500/40 shadow-sm flex flex-col gap-4">
                    <div class="w-11 h-11 rounded-xl bg-red-100 flex items-center justify-center">
                        <svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-red-500">Replace When...</h3>
                    <ul class="space-y-2 text-sm text-gray-600">
                        <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">·</span> The unit is over 10–12 years old</li>
                        <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">·</span> There is an active leak from the tank body</li>
                        <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">·</span> Repair cost exceeds 50% of a new unit</li>
                        <li class="flex items-start gap-2"><span class="text-red-500 font-bold mt-0.5">·</span> Internal corrosion or a compromised tank is evident</li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- ─── WHAT TO EXPECT ────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-200 text-base-content border-t border-base-300">
        <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
            <div class="rounded-3xl overflow-hidden shadow-xl border border-base-300">
                <img
                    src={techImg.src}
                    alt="Water Heater Replacement Company technician completing a repair"
                    loading="lazy"
                    class="w-full h-full object-cover"
                />
            </div>
            <div>
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">What to Expect</span>
                <h2 class="text-3xl sm:text-4xl font-bold mb-4">No Guesswork. No Games.</h2>
                <p class="text-gray-600 text-lg mb-5">
                    When we show up, we treat your water heater like the complex appliance it is. We do a thorough diagnostic, explain what we find in plain terms, and give you a clear written estimate before any additional work begins.
                </p>
                <p class="text-gray-600 text-lg mb-5">
                    If replacement turns out to be the right call, we can provide a quote on the spot for a same-day or next-day replacement so you're not waiting on a second appointment. You can even use our <a href="/instant-quote/?step=1" class="text-primary underline font-semibold">Exact Quote Tool</a> to get a replacement price yourself before we even arrive.
                </p>
                <ul class="grid sm:grid-cols-2 gap-3 mt-6">
                    {[
                        "Service Tank & Tankless Units",
                        "Clear estimate & diagnostic before we start",
                        "Gas & electric unit expertise",
                        "Replacement quote if needed",
                        "Same-day repairs when possible",
                        "Covered by labor warranty",
                    ].map((item) => (
                        <li class="flex items-start gap-2 text-sm font-medium text-gray-700">
                            <span class="brand-check shrink-0 mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            {item}
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </section>

    <!-- ─── SOCIAL PROOF ──────────────────────────────────────────────────────── -->
    <SocialProof />

    <!-- ─── FAQ ───────────────────────────────────────────────────────────────── -->
    <Faq faqs={faqs} name="faq-repair" />

    <UnitTypes />

    <!-- ─── FINAL CTA ─────────────────────────────────────────────────────────── -->
    <Cta
        title="Water Heater Acting Up?"
        subtitle="Call us for a professional diagnosis. We'll help you decide whether repair or replacement is the right move without a sales commission getting in the way."
    />

</BaseLayout>
