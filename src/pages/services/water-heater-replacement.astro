---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Cta from "../../components/Cta.astro";
import SocialProof from "../../components/SocialProof.astro";
import PriceReceipt from "../../components/icons/PriceReceipt.astro";
import Phone from "../../components/icons/Phone.astro";
import heroImg from "../../assets/images/whrc-van-image.webp";
import techImg from "../../assets/images/tech1.jpg";
import UnitTypes from "../../components/UnitTypes.astro";
import TrustStrip from "../../components/TrustStrip.astro";
---

<BaseLayout
    title="Water Heater Replacement in Grand Rapids | Same-Day Service"
    description="Fast, affordable water heater replacement in Grand Rapids and West Michigan. Upfront pricing, same-day installs, no hidden fees. Call or get an exact quote in 30 seconds."
    canonical="https://waterheaterreplacementcompany.com/services/water-heater-replacement/"
>

    <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
    <section class="bg-base-100 text-base-content">
        <div class="max-w-6xl mx-auto px-6 py-12 sm:py-20 grid md:grid-cols-2 gap-10 items-center">

            <!-- Left: copy -->
            <div class="flex flex-col gap-6">
                <div class="flex flex-wrap">
                    <h1 class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">
                        Water Heater Replacement · Grand Rapids & West Michigan
                    </h1>
                    <span class="text-4xl sm:text-5xl lg:text-6xl font-black leading-tight tracking-tight mb-4">
                        Water Heater Replacement Done Right, Done Fast
                    </span>
                    <p class="text-lg sm:text-xl text-gray-600 max-w-lg mt-4">
                        Skip the salesman. Get your exact installed price in 30 seconds, schedule in minutes, and have hot water today.
                    </p>
                </div>
                <div class="bg-primary/5 border border-primary/50 rounded-2xl shadow-md p-2 flex flex-wrap items-center max-w-fit px-4">
                    <span class="text-sm font-semibold text-primary">"Professional, friendly, fast, and very knowledgeable. Would highly recommend!" </span>
                    <span class="text-sm text-gray-700 leading-snug">~Pat, Jenison</span>
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                    <a href="/instant-quote/?step=1" class="btn btn-primary btn-lg text-white shadow-md">
                        <PriceReceipt />
                        Get My Exact Quote
                    </a>
                    <a href="tel:616-315-0999" class="btn btn-outline btn-lg border-primary text-primary">
                        <Phone />
                        616-315-0999
                    </a>
                </div>

                <!-- <p class="text-sm text-gray-500">Call before noon for same-day service &nbsp;·&nbsp; No email required</p> -->
            </div>

            <!-- Right: image -->
            <div class="relative">
                <img
                    src={heroImg.src}
                    alt="Water Heater Replacement Company service van in Grand Rapids"
                    loading="eager"
                    class="w-full rounded-3xl object-fit shadow-xl"
                />
                <!-- floating stat card -->
                <div class="absolute -bottom-5 -left-4 sm:left-4 bg-white border border-base-300 rounded-2xl shadow-lg px-5 py-4 flex items-center gap-3">
                    <span class="text-3xl font-black text-primary">2-Year</span>
                    <span class="text-sm font-semibold text-gray-700 leading-snug">Labor<br/>Warranties</span>
                </div>
            </div>
        </div>
    </section>

    <TrustStrip />

    <!-- ─── SIGNS YOU NEED REPLACEMENT ───────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-14">
                <span class="inline-block bg-secondary/10 text-secondary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Know the Signs</span>
                <h2 class="text-3xl sm:text-4xl font-bold mb-3">Is It Time to Replace Your Water Heater?</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Recognizing these warning signs early helps you avoid an emergency and plan for a smooth, same-day replacement.
                </p>
            </div>

            <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {[
                    {
                        title: "Unit Is 10+ Years Old",
                        desc: "Most tank water heaters last 8–12 years. If yours is approaching or past that range, replacement is likely more cost-effective than repair.",
                        icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
                    },
                    {
                        title: "Cold or Lukewarm Water",
                        desc: "Inconsistent or completely absent hot water often signals a failing heating element, thermostat, gas valve, or a tank that's past its useful life.",
                        icon: "M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z",
                    },
                    {
                        title: "Leaking from the Tank",
                        desc: "A leak from the tank body — not a fitting — almost always means internal corrosion that cannot be repaired. Act fast to prevent water damage and have it replaced promptly.",
                        icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
                    },
                    {
                        title: "Rusty or Discolored Water",
                        desc: "Brown or reddish water from your hot taps signals internal tank corrosion or a failing anode rod — both signs the unit is near the end of its life.",
                        icon: "M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z",
                    },
                    {
                        title: "Strange Noises",
                        desc: "Popping, rumbling, or banging sounds are caused by hardened sediment buildup on the tank floor. It reduces capacity and accelerates wear on the tank walls.",
                        icon: "M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15.536a5 5 0 001.414 1.414m2.828-9.9a9 9 0 0112.728 0",
                    },
                    {
                        title: "Rising Energy Bills",
                        desc: "Aging tanks work harder to maintain temperature, especially with sediment insulating the burner. A new high-efficiency unit will lower your monthly costs.",
                        icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
                    },
                ].map(({ title, desc, icon }) => (
                    <div class="flex gap-4 p-6 bg-base-100 rounded-2xl border border-base-300 shadow-sm hover:shadow-md transition-shadow">
                        <div class="shrink-0 w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center mt-0.5">
                            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-base-content mb-1">{title}</h3>
                            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ─── HOW IT WORKS ──────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-200 text-base-content border-t border-base-300">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Simple Process</span>
                <h2 class="text-3xl sm:text-4xl font-bold">From Quote to Hot Water</h2>
                <p class="text-gray-600 mt-3 max-w-xl mx-auto">Three ways to get started — one straightforward process from there.</p>
            </div>

            <div class="flex flex-col gap-4">

                <!-- STEP 01: full-width with 3 contact options -->
                <div class="bg-white rounded-3xl border border-base-300 shadow-sm p-7 sm:p-8">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-12 h-12 rounded-full bg-primary text-white text-lg font-black flex items-center justify-center shadow-md shrink-0">01</div>
                        <div>
                            <p class="text-xs font-bold tracking-widest uppercase text-primary">Get Started</p>
                            <h3 class="text-xl font-bold leading-snug">Get Your Exact Price — 3 Ways</h3>
                        </div>
                    </div>
                    <div class="grid sm:grid-cols-3 gap-4">

                        <!-- Option A: Quote Tool (primary) -->
                        <a href="/instant-quote/?step=1" class="group flex flex-col gap-3 p-5 border-primary border-1 rounded-2xl bg-primary/10 text-primary shadow hover:shadow-md transition-shadow">
                            <div class="w-9 h-9 rounded-xl bg-white/20 flex items-center justify-center">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                                </svg>
                            </div>
                            <div>
                                <p class="font-bold text-sm">Use our Exact Quote Tool</p>
                                <p class="text-xs text-primary mt-1 leading-relaxed">Get an exact price in seconds. No email or phone call needed.</p>
                            </div>
                            <span class="text-xs font-bold mt-auto underline underline-offset-2">Get My Price Now →</span>
                        </a>

                        <!-- Option B: Call -->
                        <a href="tel:616-315-0999" class="group flex flex-col gap-3 p-5 rounded-2xl bg-base-100 border border-base-300 hover:border-primary/30 hover:shadow-md transition-all">
                            <div class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center">
                                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                            </div>
                            <div>
                                <p class="font-bold text-sm text-base-content">Give Us a Call</p>
                                <p class="text-xs text-gray-500 mt-1 leading-relaxed">We'll walk through a few standard questions and provide pricing in minutes.</p>
                            </div>
                            <span class="text-xs font-bold text-primary mt-auto underline underline-offset-2">616-315-0999 →</span>
                        </a>

                        <!-- Option C: Text a photo -->
                        <a href="sms:+16163150999?body=Hi%2C%20I%27d%20like%20a%20quote%20to%20replace%20this%20water%20heater.%20My%20name%20is%20" class="group flex flex-col gap-3 p-5 rounded-2xl bg-base-100 border border-base-300 hover:border-primary/30 hover:shadow-md transition-all">
                            <div class="w-9 h-9 rounded-xl bg-primary/10 flex items-center justify-center">
                                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                                </svg>
                            </div>
                            <div>
                                <p class="font-bold text-sm text-base-content">Text a Photo</p>
                                <p class="text-xs text-gray-500 mt-1 leading-relaxed">Snap a photo of your entire unit, include your name, and we'll reply with a price.</p>
                            </div>
                            <span class="text-xs font-bold text-primary mt-auto underline underline-offset-2">Open Messaging →</span>
                        </a>

                    </div>
                </div>

                <!-- STEPS 02 + 03 side by side -->
                <div class="grid sm:grid-cols-2 gap-4">

                    <div class="bg-white rounded-3xl border border-base-300 shadow-sm p-7 sm:p-8 flex flex-col gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 rounded-full bg-primary/10 text-primary text-lg font-black flex items-center justify-center shrink-0">02</div>
                            <div>
                                <p class="text-xs font-bold tracking-widest uppercase text-gray-400">If Needed</p>
                                <h3 class="text-xl font-bold leading-snug">We Verify Your Setup</h3>
                            </div>
                        </div>
                        <p class="text-gray-600 text-sm leading-relaxed">A quick photo or short video call lets us confirm your setup matches what you were quoted. This ensures no surprises on install day and that we arrive with exactly the right parts and equipment.</p>
                    </div>

                    <div class="bg-white rounded-3xl border border-base-300 shadow-sm p-7 sm:p-8 flex flex-col gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-12 h-12 rounded-full bg-primary/10 text-primary text-lg font-black flex items-center justify-center shrink-0">03</div>
                            <div>
                                <p class="text-xs font-bold tracking-widest uppercase text-gray-400">Done Right</p>
                                <h3 class="text-xl font-bold leading-snug">Schedule & Get Hot Water</h3>
                            </div>
                        </div>
                        <p class="text-gray-600 text-sm leading-relaxed">We install your new unit, haul away the old one, clean up, and test everything before we leave. Most installs take 2–4 hours. Same-day and next-day appointments available throughout West Michigan.</p>
                    </div>

                </div>
            </div>
        </div>
    </section>

    <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-12 items-center">
            <div>
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-4">Everything Included</span>
                <h2 class="text-3xl sm:text-4xl font-bold mb-4">One Price. No Surprises.</h2>
                <p class="text-gray-600 text-lg mb-8">
                    Your quote includes everything needed for a code-compliant, same-day or next-day installation. We bring the unit and parts needed, handle the permits, and leave your space spotless.
                </p>
                <ul class="grid sm:grid-cols-2 gap-3">
                    {[
                        "New professional grade water heater",
                        "All labor - from start to finish",
                        "Mechanical permit handling",
                        "Haul-away of old unit",
                        "Shut-off valves & venting connections",
                        "Safety drain pan and piping installed",
                        "Water leak alarm installed",
                        "100% code-compliant installation",
                        "Full system test before we leave",
                        "2-Year labor warranty on every job",
                    ].map((item) => (
                        <li class="flex items-start gap-2 text-sm font-medium text-gray-700">
                            <span class="brand-check shrink-0 mt-0.5">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            {item}
                        </li>
                    ))}
                </ul>
            </div>
            <div class="rounded-3xl overflow-hidden shadow-xl border border-base-300">
                <img
                    src={techImg.src}
                    alt="Water Heater Replacement Company technician completing a clean installation"
                    loading="lazy"
                    class="w-full h-full object-cover"
                />
            </div>
        </div>
    </section>

    <UnitTypes />

    <!-- ─── WHY CHOOSE US ─────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">Why Us</span>
                <h2 class="text-3xl sm:text-4xl font-bold">The Better Way to Replace Your Water Heater</h2>
                <p class="text-gray-600 text-lg mt-3 max-w-2xl mx-auto">We're a water heater specialty shop, not a general plumber. That focus means faster installs, better inventory, honest pricing, and no wasted time.</p>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {[
                    {
                        icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z",
                        title: "Guaranteed Pricing",
                        desc: "The price we verify is the price you pay. No salesmen, no commissions, no upsell pressure, and absolutely no surprise charges or fees.",
                    },
                    {
                        icon: "M5 13l4 4L19 7",
                        title: "2-Year Labor Warranty",
                        desc: "We are professionals who stand behind our work with a region-leading 2-year labor warranty standard on every job, at no additional cost.",
                    },
                    {
                        icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
                        title: "Respectful & On Time",
                        desc: "We protect your floors, clean up when we're done, and finish most installs in just a few hours. We're also pretty easy to get along with. :)",
                    },
                    {
                        icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
                        title: "Licensed & Local",
                        desc: "We are experienced professionals who handle permits and bring every install up to code. No subcontractors — just our local West Michigan team.",
                    },
                    {
                        icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z",
                        title: "Top-Tier Units",
                        desc: "We install professional-grade Rheem water heaters backed by industry-leading manufacturer warranties. Other brands may be available upon request.",
                    },
                    {
                        icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
                        title: "Serving West Michigan",
                        desc: "Proudly serving our neighbors throughout West Michigan, including Grand Rapids, Holland, Rockford, East GR, and more.",
                    },
                ].map(({ icon, title, desc }) => (
                    <div class="bg-base-100 rounded-2xl p-6 border border-base-300 shadow-sm flex flex-col gap-4 hover:shadow-md transition-shadow">
                        <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold text-lg mb-1">{title}</h3>
                            <p class="text-sm text-gray-600 leading-relaxed">{desc}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ─── SOCIAL PROOF ──────────────────────────────────────────────────────── -->
    <SocialProof />

    <!-- ─── FAQ ───────────────────────────────────────────────────────────────── -->
    <section class="py-20 px-6 bg-base-100 text-base-content border-t border-base-300">
        <div class="max-w-3xl mx-auto">
            <div class="text-center mb-10">
                <span class="inline-block bg-primary/10 text-primary text-xs font-bold tracking-widest uppercase px-3 py-1 rounded-full mb-3">FAQ</span>
                <h2 class="text-3xl sm:text-4xl font-bold">Common Questions</h2>
            </div>

            <div class="flex flex-col gap-3">
                {[
                    {
                        q: "How much does a water heater replacement cost in Grand Rapids?",
                        a: `Costs vary based on the unit type, size, venting requirements, and your home's setup. Use our <a href="/instant-quote/?step=1" class="text-primary underline font-semibold">Exact Quote tool</a> to see a real installed price in 30 seconds — no email required. Or <a href="tel:1234567890" class="text-primary underline font-semibold">call us</a> and get a quote over the phone in minutes.`,
                    },
                    {
                        q: "How long does a replacement take?",
                        a: "Most standard tank water heater replacements take 2–4 hours from arrival to hot water restored. Complex setups with venting changes or unit relocations may take longer, but we'll let you know up front. Tankless water heater installations typically take a full day - sometimes more - due to the additional plumbing and electrical work involved. Again, we'll be clear about the timeline before we start so you know what to expect. But we always get the hot water flowing as soon as possible without cutting corners on quality or safety.",
                    },
                    {
                        q: "Do you handle permits?",
                        a: "Yes. A mechanical permit is required for every water heater replacement in Michigan. We apply for the permit, handle the scheduling, and make sure everything is code compliant — all included in your price. Some contractors skip this to save money, time and hassle; we won't. It is required by the state for your protection and ensures the work is inspected for safety and code compliance. If you see a quote that doesn't include a permit, or a contractor that offers a discount to bypass an inspection, that's a red flag and you should avoid them.",
                    },
                    {
                        q: "What brands do you install?",
                        a: "We primarily install Rheem professional grade units, not the budget models sold at big-box stores. Rheem water heaters carry strong manufacturer warranties and are well-suited to West Michigan's water conditions. Other brands may be available upon request, but we find Rheem offers the best combination of reliability, efficiency, and value for our customers. If you have a specific brand in mind, just ask and we'll do our best to accommodate.",
                    },
                    {
                        q: "Can you replace it the same day?",
                        a: "In many cases, yes. If you contact us early enough we can often complete the install same-day. Next-day appointments are also typically available throughout the West Michigan area.",
                    },
                    {
                        q: "Do I need to be home during the installation?",
                        a: "Yes, someone 18 or older needs to be present for the installation and to pay and sign off on the completed work. Most installs are done in 2-4 hours so you won't be waiting around all day. :)",
                    },
                ].map(({ q, a }, i) => (
                    <div class="collapse collapse-arrow border border-base-300 rounded-2xl bg-base-100">
                        <input type="radio" name="faq-replacement" checked={i === 0} />
                        <div class="collapse-title text-base font-semibold py-5 pr-10">{q}</div>
                        <div class="collapse-content text-gray-600 text-sm leading-relaxed">
                            <p set:html={a} />
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ─── FINAL CTA ─────────────────────────────────────────────────────────── -->
    <Cta
        title="Ready to Replace Your Water Heater?"
        subtitle="Get an exact installed price in 30 seconds — no email, no salesman, no surprises."
    />

</BaseLayout>
