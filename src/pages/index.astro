---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import SocialProof from '../components/SocialProof.astro';
import Cta from '../components/Cta.astro';
import Faq from '../components/Faq.astro';
import HelpButton from '../components/HelpButton.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ArrowDown from '../components/icons/ArrowDown.astro';

const faqs = [
	{
        q: "How much does a water heater replacement cost?",
        a: `We don't do 'estimates' because we know our business. Use our 30-second <a href="/instant-quote/?step=1" class="underline font-semibold text-secondary">Exact Quote tool</a> to get an <span class="font-semibold text-primary">actual installed price</span> for your specific home. This includes the unit, labor, permits, and even the haul-away of your old tank. The price you see online is the price you'll see on your invoice after installation. How can we do this? Because we specialize in water heaters and verify your home's setup via photo, video, or in-person visit - whatever is easiest for you - before we schedule the job. No surprises. No gimmicks. Just honest, upfront pricing.`,
    },
    {
        q: "Do I really get a price without giving my email?",
        a: `Yes. You get an exact price without a sales pitch. We believe that if we give you a fair, honest price upfront, you'll hire us because we're the easiest company to work with in West Michigan. And dare we say, the funnest? What do you call an extremely unappreciative water heater? ...Tankless.<br/><br/>But seriously, we're always here if you have questions or need more details. <a aria-label="call 616-315-0999" href="tel:616-315-0999" class="underline text-primary">Call 616-315-0999</a> anytime.`,
    },
    {
        q: "Why do I need to send a photo or join a video call to verify my price?",
        a: `The video call isn't for us to 'sell' you—it's for us to guarantee your price. Your <a href="/instant-quote/?step=1" class="underline font-semibold text-secondary">Exact Quote</a> is locked as soon as we verify your home details. We check for items like chimney liners or specific piping and valve needs so we can arrive with the right parts and ensure there are no surprises once we're on-site.<br/><br/>In the case of in-person checks, we send a technician to your home for a quick 10-minute visit to verify those same details. We do stock several of the most common water heater models in each van so if everything checks out, we can often begin the install right then.<br/><br/>Either way, there's no cost or obligation to move forward. We want you to feel 100% comfortable in your decision.`,
    },
    {
        q: "How do I know if I need a new water heater?",
        a: "Most tank water heaters last around 10–12 years. Signs you may need a replacement include inconsistent hot water, strange noises, water around the base, rusty water, or increasing energy bills. If your unit is over 10 years old and showing these signs, it's usually most cost-effective to replace it.",
    },
    {
        q: "Can you replace my water heater the same day?",
        a: "In many cases, yes. If you call early in the day and we have access to the unit size/type you need, we can replace it same-day. We also offer next-day appointments.",
    },
    {
        q: "What if I'm not sure what type of water heater I have now?",
        a: "No problem — just answer a few simple questions (or send a photo), and we'll identify your current setup. From there, we'll match you with the most compatible replacement or help you explore high efficiency options if desired.",
    },
    {
        q: "Do I need a permit to replace my water heater in West Michigan?",
        a: "Yes — whether you are in Grand Rapids or Grandville, Hudsonville or Holland, a plumbing/mechanical permit is required. We handle the permitting process and make sure your install is up to code so you don't have to worry. An inspector may schedule an inspection after the install to verify everything is safe and code compliant.",
    },
    {
        q: "Do you service both gas and electric water heaters?",
        a: "Yes. We install and replace both gas and electric water heaters, including tank, tankless, and hybrid models. We'll confirm your home's fuel type during the quote process to ensure you get the right model. Need to switch from gas to electric or vice versa? We can help with that too, but keep in mind it may require additional work like electrical upgrades or gas line installation, which will require a site visit.",
    },
    {
        q: "Can I upgrade to a tankless system?",
        a: `Yes, you can absolutely upgrade to a tankless system. Keep in mind not every home is ready for one simply by removing your old water heater — they often require gas line upgrades, rerouting water lines, additional venting, and an outlet installed nearby. We may even need to install a chimney liner if your old water heater shared a chimney with your furnace or boiler.<br/><br/>While tankless upgrades have more variables, our 30-second <a href="/instant-quote/?step=1" class="text-secondary underline font-bold">Exact Quote tool</a> will give you a clear baseline. We'll then verify your home's setup via photo, video, or in-person to give you a guaranteed, locked-in quote before we even pull into your driveway.`,
    },
    {
        q: "How long does the installation take?",
        a: "Most standard replacements take about 2–4 hours. If your setup is more complex or requires relocation or venting changes, we'll let you know up front.",
    },
    {
        q: "Will I be without hot water during the install?",
        a: "Yes, but only briefly. We'll disconnect your old unit and install the new one the same day. Hot water is typically restored within a few hours of arrival so you can move on with your day (after a hot shower, of course).",
    },
    {
        q: "Do you dispose of the old water heater?",
        a: "Yes. Unless you'd like to keep it as a memento, we always remove and dispose of your old water heater and clean up the area after every replacement. You won't even know we were there...well, it might actually be cleaner than it was before.",
    },
    {
        q: "Is the work guaranteed?",
        a: `Yes — every job includes a minimum <span class="font-bold">2-Year Labor Warranty</span>, a <span class="font-bold">Manufacturer Warranty</span>, and a <span class="font-bold">Satisfaction Guarantee</span>. We install everything to meet code requirements so you won't have issues during home sales, inspections, or insurance claims.<br/><br/>Most tanks include a 6-12 year manufacturer warranty. Tankless units include a 10-12 year heat exchanger warranty and 5 year parts warranty. Extended labor and equipment warranties are also available starting at $295.`,
    },
];

---

<BaseLayout faqs={faqs}>
	<!-- <HelpButton /> -->
	<Hero />
	<TrustStrip />
	<HowItWorks />
	<WhyChooseUs />
	<SocialProof />
	<Cta />
	<Faq faqs={faqs} />
	<!-- ─── SEO: TOPICAL AUTHORITY ───────────────────────────────────────────── -->
	<section class="bg-primary/10 py-20 px-6 text-base-content border-t border-base-300">
		<div class="max-w-5xl mx-auto space-y-16">

			<!-- ── Intro ── -->
			<div>
				<h2 class="text-2xl sm:text-3xl font-bold mb-4">Water Heater Services in West Michigan</h2>
				<p class="text-gray-600 leading-relaxed max-w-3xl">
					We specialize exclusively in water heater replacement, installation, and repair — tank and tankless — for homeowners across West Michigan. Unlike general plumbers who handle everything, our entire operation is built around one thing: getting you a new water heater quickly, cleanly, and at a price you know before we arrive. We serve Grand Rapids, Jenison, Hudsonville, Holland, Zeeland, and surrounding communities throughout Kent and Ottawa counties.
				</p>
			</div>

			<!-- ── Services Grid ── -->
			<div>
				<h3 class="text-xl font-bold mb-6">Water Heater Services We Offer</h3>
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
					{[
						{
							title: "Water Heater Replacement",
							desc: "Same-day and next-day replacement of failed or aging tank and tankless water heaters throughout West Michigan.",
							href: "/services/water-heater-replacement/",
							anchor: "Water Heater Replacement Services →",
						},
						{
							title: "Tank Water Heater Installation",
							desc: "Gas, electric, and propane tank water heaters in 30, 40, 50, and 75-gallon configurations. Includes permit and haul-away.",
							href: "/resources/tank-water-heaters/",
							anchor: "About Tank Water Heaters →",
						},
						{
							title: "Tankless Water Heater Installation",
							desc: "Whole-home tankless water heater installation in West Michigan. Gas and propane only. Includes venting, gas line assessment, and permit.",
							href: "/resources/tankless-water-heaters/",
							anchor: "About Tankless Water Heaters →",
						},
						{
							title: "Water Heater Repair Services",
							desc: "Diagnosis and repair for water heaters that aren't heating, are making noise, or have pressure and thermostat issues.",
							href: "/services/water-heater-repair/",
							anchor: "Water Heater Repair →",
						},
						{
							title: "Leaking Water Heater Emergency",
							desc: "Leaking tank bodies require immediate replacement. We prioritize emergency calls with same-day availability throughout our service area.",
							href: "/services/leaking-water-heater-emergency/",
							anchor: "Leaking Water Heater Help →",
						},
						{
							title: "Tank vs. Tankless Comparison",
							desc: "Not sure which system is right for your home? We install both and have no stake in what you choose — just an honest comparison.",
							href: "/resources/tank-vs-tankless-water-heaters/",
							anchor: "Compare Tank vs. Tankless →",
						},
					].map(({ title, desc, href, anchor }) => (
						<div class="bg-base-100 rounded-2xl border border-base-300 p-6 shadow-sm flex flex-col gap-3">
							<h4 class="font-bold text-base-content">{title}</h4>
							<p class="text-sm text-gray-600 leading-relaxed flex-1">{desc}</p>
							<a href={href} class="text-sm font-semibold text-primary hover:underline">{anchor}</a>
						</div>
					))}
				</div>
			</div>

			<!-- ── Local Service Areas ── -->
			<div>
				<h3 class="text-xl font-bold mb-4">Local Water Heater Replacement Service Areas</h3>
				<p class="text-gray-600 text-sm leading-relaxed mb-6 max-w-3xl">We serve homeowners throughout Kent and Ottawa counties. Same-day and next-day availability in all areas listed below.</p>
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
					{[
						{ label: "Water Heater Replacement in Jenison", href: "/service-area/jenison/" },
						{ label: "Grand Rapids Water Heater Installation", href: "/service-area/grand-rapids/" },
						{ label: "Hudsonville Water Heater Replacement", href: "/service-area/hudsonville/" },
						{ label: "Grandville Water Heater Services", href: "/service-area/grandville/" },
						{ label: "Holland MI Tankless Water Heaters", href: "/service-area/holland/" },
						{ label: "Zeeland Water Heater Replacement", href: "/service-area/zeeland/" },
						{ label: "Wyoming MI Water Heater Installation", href: "/service-area/wyoming/" },
						{ label: "Kentwood Water Heater Replacement", href: "/service-area/kentwood/" },
						{ label: "Walker Water Heater Services", href: "/service-area/walker/" },
					].map(({ label, href }) => (
						<a href={href} class="flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-primary transition-colors p-3 bg-base-100 rounded-xl border border-base-300">
							<svg class="w-4 h-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
							{label}
						</a>
					))}
				</div>
				<p class="text-sm text-gray-500 mt-4">Also serving Comstock Park, Byron Center, East Grand Rapids, Ada, Caledonia, and more. <a href="/service-area/" class="text-primary hover:underline font-medium">View our full service area →</a></p>
			</div>

			<!-- ── Common Problems ── -->
			<div>
				<h3 class="text-xl font-bold mb-4">Common Water Heater Problems That Lead to Replacement</h3>
				<p class="text-gray-600 text-sm leading-relaxed mb-5 max-w-3xl">Most water heater failures follow a predictable pattern. Recognizing these signs early gives you time to plan a replacement rather than scramble during an emergency.</p>
				<ul class="grid sm:grid-cols-2 gap-3">
					{[
						["No hot water or inconsistent temperature", "A failed heating element, gas valve, or thermostat — or a tank simply past its prime."],
						["Leaking water heater tank", "A leak from the tank body (not a fitting) almost always signals internal corrosion. The unit needs replacing, not patching."],
						["Rusty or discolored hot water", "Brown or reddish water from your hot taps means the tank interior is corroding — a sign the unit is near end of life."],
						["Popping or rumbling noises", "Mineral sediment hardened at the base of the tank. It reduces efficiency and accelerates wear."],
						["Rising energy bills without explanation", "Aging tanks work harder to maintain temperature, especially as sediment builds up on heating surfaces."],
						["Tank is 10–15 years old", "Most tank water heaters last 8–12 years. If yours is in this range, proactive replacement avoids an emergency."],
					].map(([problem, detail]) => (
						<li class="flex items-start gap-3 p-4 bg-base-100 rounded-xl border border-base-300 text-sm text-gray-700">
							<svg class="w-4 h-4 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
							<span><strong>{problem}</strong> — {detail}</span>
						</li>
					))}
				</ul>
				<p class="text-sm text-gray-500 mt-4">See the full guide: <a href="/resources/common-water-heater-problems-west-michigan/" class="text-primary hover:underline font-medium">Common Water Heater Problems in West Michigan →</a></p>
			</div>

			<!-- ── Tank vs Tankless + Pricing ── -->
			<div class="grid sm:grid-cols-2 gap-8 items-start">
				<div>
					<h3 class="text-xl font-bold mb-4">Tank vs. Tankless Water Heaters</h3>
					<p class="text-gray-600 text-sm leading-relaxed mb-3">Tank water heaters store 40–75 gallons of heated water, cost less upfront, and work with any fuel type. Tankless units heat water on demand — no tank, no standby energy loss — but require natural gas or propane and cost more to install. Both are excellent choices; the right one depends on your household size, fuel type, and budget.</p>
					<p class="text-gray-600 text-sm leading-relaxed mb-4">In West Michigan, water hardness is also a factor. Hard well water in Ottawa County communities like Hudsonville accelerates scale buildup differently in each system type.</p>
					<a href="/resources/tank-vs-tankless-water-heaters/" class="text-sm font-semibold text-primary hover:underline">Full tank vs. tankless water heater comparison →</a>
				</div>
				<div>
					<h3 class="text-xl font-bold mb-4">Water Heater Replacement Cost in Michigan</h3>
					<p class="text-gray-600 text-sm leading-relaxed mb-3">Water heater installation prices vary based on the unit type, fuel source, tank size, venting configuration, and whether any upgrades (gas line, expansion tank, drain pan) are required. Tank replacements in West Michigan typically fall in the $1,500–$2,995 range; tankless installations start around $3,995 installed.</p>
					<p class="text-gray-600 text-sm leading-relaxed mb-4">Every quote from us includes parts, labor, permit, haul-away, and a 2-year labor warranty — no line items added at the door. Skip the guesswork and get your exact installed price in 30 seconds.</p>
					<a href="/instant-quote/?step=1" class="text-sm font-semibold text-primary hover:underline">Get your exact installed price →</a>
				</div>
			</div>

			<!-- ── Educational Resources ── -->
			<div>
				<h3 class="text-xl font-bold mb-5">Water Heater Guides & Resources</h3>
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
					{[
						{
							title: "Water Heater Installation Process",
							desc: "A step-by-step walkthrough of what happens on installation day — from arrival to hot water restored.",
							href: "/resources/water-heater-installation-process-jenison-mi/",
							anchor: "How installation works →",
						},
						{
							title: "Common Water Heater Problems",
							desc: "Signs your water heater is failing, what causes them, and when repair vs. replacement makes more sense.",
							href: "/resources/common-water-heater-problems-west-michigan/",
							anchor: "Water heater troubleshooting guide →",
						},
						{
							title: "Tank vs. Tankless Comparison Guide",
							desc: "A side-by-side breakdown of cost, lifespan, efficiency, and which type suits West Michigan homes.",
							href: "/resources/tank-vs-tankless-water-heaters/",
							anchor: "Compare tank vs. tankless →",
						},
						{
							title: "Get Your Exact Installed Price",
							desc: "Answer a few quick questions about your home and get a real installed price in 30 seconds — no email, no salesman.",
							href: "/instant-quote/?step=1",
							anchor: "Get my exact quote →",
						},
						{
							title: "Tank Water Heaters",
							desc: "Gas, electric, and propane tank options, sizing guidance, and which models we install.",
							href: "/resources/tank-water-heaters/",
							anchor: "Tank water heater overview →",
						},
						{
							title: "Tankless Water Heaters",
							desc: "How tankless systems work, who they're best for, and what installation looks like in a West Michigan home.",
							href: "/resources/tankless-water-heaters/",
							anchor: "Tankless water heater overview →",
						},
					].map(({ title, desc, href, anchor }) => (
						<div class="bg-base-100 rounded-2xl border border-base-300 p-6 shadow-sm flex flex-col gap-3">
							<h4 class="font-bold text-base-content">{title}</h4>
							<p class="text-sm text-gray-600 leading-relaxed flex-1">{desc}</p>
							<a href={href} class="text-sm font-semibold text-primary hover:underline">{anchor}</a>
						</div>
					))}
				</div>
			</div>

		</div>
	</section>
	<Cta title="Not Sure Yet? Let’s Walk Through It Together." subtitle="We’ll guide you through your options and give you straight answers, not sales pitches." />
</BaseLayout>
