---
import BaseLayout from '../../layouts/BaseLayout.astro';
import exampleWidePhoto from '../../assets/images/reviews/50-gallon-atmospheric-water-heater-installation-cedar-lake-jenison-mi-hippey.jpg';
import exampleDataPlatePhoto from '../../assets/images/wh-data-sticker.jpg';
import { confirmationVariants, getConfirmationVariant, parsePhotoCount } from '../../data/confirmationVariants';

const requestUrl = Astro.request?.url ? new URL(Astro.request.url) : Astro.url;
const rawPhotoCount = requestUrl.searchParams.get('photo_count') || Astro.url.searchParams.get('photo_count');
const photoCount = parsePhotoCount(rawPhotoCount);
const content = getConfirmationVariant(photoCount);
const serializedVariants = JSON.stringify(confirmationVariants);
const phoneNumber = '616-315-0999';
const smsHref = `sms:+16163150999?&body=${encodeURIComponent(content.smsBody ?? 'Hello, here are 2 photos of my water heater for price verification.')}`;
const timelinePhases = photoCount > 0
    ? (content.phases ?? [])
    : [];
---

<BaseLayout
    title="Thanks! We Received Your Water Heater Request"
    description="Your information was submitted successfully."
    canonical="https://waterheaterreplacementcompany.com/forms/confirmation/"
    robotsIndex={false}
    robotsFollow={false}
    showNavigation={false}
    showFooter={false}
>
    <main class="mx-auto max-w-5xl px-4 pb-12 pt-6">
        <section id="confirmation-root" data-variants={serializedVariants} class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
            <div class="bg-primary px-6 py-4 text-white md:px-8">
                <p class="text-xs font-bold uppercase tracking-wide text-white/80">Submission Confirmed</p>
                <h1 id="submission-headline" class="mt-1 text-2xl font-black tracking-tight md:text-3xl">{content.headline}</h1>
            </div>

            <div class="px-6 py-6 md:px-8 md:py-8 space-y-8">
                <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 md:p-6">
                    <p id="receipt-message" class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Got it!</p>
                    <p id="receipt-body" class="mt-2 text-slate-800 leading-relaxed">{content.body}</p>
                </div>

                <section id="photo-upload-section" class:list={{ hidden: photoCount > 0 }} class="rounded-2xl border border-slate-200 bg-slate-50 p-5 md:p-6">
                    <p id="section-kicker" class="text-xs font-bold uppercase tracking-wide text-primary">{content.middleTitle}</p>
                    <h2 id="section-title" class="mt-2 text-xl font-bold text-slate-900">{content.middleTitle}</h2>
                    <p id="section-subtitle" class="mt-2 text-slate-700 leading-relaxed">{content.middleSubtitle}</p>

                    {photoCount === 0 && (
                        <div class="mt-5 grid gap-4 md:grid-cols-2">
                            <article class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                                <div class="border-b border-slate-200 bg-slate-50 p-3">
                                    <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Example 1</p>
                                    <h3 class="text-base font-bold text-slate-900">Wide View</h3>
                                </div>
                                <div class="p-3">
                                    <p class="text-sm text-slate-600">Show the full tank and piping above it.</p>
                                    <img
                                        src={exampleWidePhoto.src}
                                        alt="Example wide photo of a water heater installation showing the full tank and connected piping"
                                        class="mt-3 w-full rounded-lg object-cover object-center"
                                        loading="lazy"
                                    />
                                </div>
                            </article>

                            <article class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                                <div class="border-b border-slate-200 bg-slate-50 p-3">
                                    <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Example 2</p>
                                    <h3 class="text-base font-bold text-slate-900">Data Sticker Close-Up</h3>
                                </div>
                                <div class="p-3">
                                    <p class="text-sm text-slate-600">Capture the manufacturer label so we can verify the exact model.</p>
                                    <img
                                        src={exampleDataPlatePhoto.src}
                                        alt="Example close-up photo of a water heater data sticker showing model and serial information"
                                        class="mt-3 w-full rounded-lg object-cover object-center"
                                        loading="lazy"
                                    />
                                </div>
                            </article>
                        </div>
                    )}

                    {photoCount > 0 && (
                        <div class="mt-5 max-w-xl">
                            <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-900">
                                One photo is enough. We will take it from here and follow up with the next step.
                            </div>
                        </div>
                    )}

                    <div class="mt-5">
                        <a
                            id="primary-cta"
                            href={smsHref}
                            class="inline-flex w-full items-center justify-center rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-primary/90 sm:w-auto"
                            aria-label={content.buttonText}
                        >
                            {content.buttonText}
                        </a>
                        <p id="prefilled-text" class="mt-3 text-sm text-slate-500">Prefilled text: &quot;{content.smsBody}&quot;</p>
                    </div>
                </section>

                <section id="timeline-section" class:list={{ hidden: photoCount === 0 }} class="rounded-2xl border border-slate-200 bg-slate-50 p-5 md:p-6">
                    <p id="timeline-kicker" class="text-xs font-bold uppercase tracking-wide text-primary">{content.timelineTitle}</p>
                    <h2 id="timeline-title" class="mt-2 text-xl font-bold text-slate-900">{content.timelineTitle}</h2>

                    <div id="timeline-grid" class="mt-5 space-y-4">
                        {timelinePhases.map((phase, index) => (
                            <article class="flex gap-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
                                <div class="flex flex-col items-center">
                                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-sm font-bold text-emerald-800">{index + 1}</div>
                                    {index < timelinePhases.length - 1 && <div class="mt-3 h-full w-px flex-1 bg-slate-200" aria-hidden="true"></div>}
                                </div>
                                <div>
                                    <p class="text-xs font-bold uppercase tracking-wide text-slate-500">{index === 0 ? 'Up Next' : index === 1 ? 'Quote Verification' : 'Priority Booking'}</p>
                                    <h3 class="mt-1 text-base font-bold text-slate-900">{phase.title}</h3>
                                    <p class="mt-2 text-sm leading-relaxed text-slate-700">{phase.description}</p>
                                </div>
                            </article>
                        ))}
                    </div>
                </section>

                <section id="fallback-section" class="rounded-2xl border border-slate-200 bg-white p-5 md:p-6">
                    <p id="fallback-kicker" class="text-xs font-bold uppercase tracking-wide text-slate-500">{content.fallbackTitle}</p>
                    <h2 id="fallback-title" class="mt-2 text-xl font-bold text-slate-900">{content.fallbackTitle}</h2>
                    <p id="fallback-subtitle" class="mt-2 text-slate-700 leading-relaxed">{content.fallbackSubtitle}</p>

                    <div class="mt-5 flex flex-col gap-3 sm:flex-row">
                        <a
                            href={`tel:+1${phoneNumber.replace(/\D/g, '')}`}
                            class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-bold text-slate-900 transition hover:bg-slate-50"
                        >
                            Call {phoneNumber}
                        </a>
                        <a
                            href={smsHref}
                            class="inline-flex items-center justify-center rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-primary/90"
                        >
                            Text Us
                        </a>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <script type="module" src="/scripts/confirmation-variant.js"></script>
</BaseLayout>
