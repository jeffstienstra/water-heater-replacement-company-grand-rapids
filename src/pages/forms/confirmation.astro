---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoVerificationInstructions from '../../components/PhotoVerificationInstructions.astro';
---

<BaseLayout
    title="Thanks! We Received Your Water Heater Request"
    description="Your information was submitted successfully. The easiest next step is texting two photos for quick verification."
    canonical="https://waterheaterreplacementcompany.com/forms/confirmation/"
    robotsIndex={false}
    robotsFollow={false}
    showNavigation={false}
    showFooter={false}
>
    <main class="mx-auto max-w-5xl px-4 pb-12 pt-6">
        <PhotoVerificationInstructions
            heading="Submission Received. Easiest Next Step: Text 2 Photos"
            description="Your information was submitted and we received it successfully. The fastest way to move forward is to text us these two photos now."
            showAlternateOptions={true}
        />
    </main>
</BaseLayout>
